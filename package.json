{
  "name": "skim-page-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @skim-page/playground-web run dev",
    "build": "npm --workspace @skim-page/playground-web run build && npm --workspace @skim-page/extension run build",
    "build:extension": "npm --workspace @skim-page/extension run build",
    "check:extension": "node scripts/check-extension-build.mjs",
    "test": "npm run test:core && npm run test:extension-storage && npm run build:extension && npm run check:extension",
    "test:core": "node scripts/test-core-prompts.mjs",
    "test:extension-storage": "node scripts/test-extension-storage.mjs",
    "preview": "npm --workspace @skim-page/playground-web run preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
