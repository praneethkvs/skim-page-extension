{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@skim-page/core": ["../../packages/core/src"]
    },
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src", "../../packages/core/src"]
}
